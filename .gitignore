*.tfstate.*
.terraform/
*.tfvars
!*.tfvars.example
crash.log

# kubeconfig & cluster joins
kubeconfig
*kubeconfig*
k3s.yaml
node-token
*.token

# secrets / env
.env
.env.*
!.env.example
*secret*.yaml
!*secret*.example.yaml
*.pem
*.key
id_rsa*

# argo / helm local
charts/*.tgz

# os / editor
.DS_Store
*.swp
.idea/
.vscode/
